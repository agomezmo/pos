[Unit]
Description=POS Farmacia Express - Sistema de Punto de Venta
Requires=docker.service
After=docker.service network-online.target billar.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/agomezmo/proyectos/pos
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
ExecReload=/usr/bin/docker compose restart
StandardOutput=journal
User=agomezmo
Group=docker
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
